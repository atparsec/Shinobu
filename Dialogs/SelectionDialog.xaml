<UserControl
    x:Class="Shinobu.Dialogs.SelectionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    MaxWidth="600"
    MinWidth="600"
    MinHeight="500"
    >

    <Border Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}" CornerRadius="8" BorderBrush="{ThemeResource ControlElevationBorderBrush}" BorderThickness="1" Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <NavigationView
                Grid.Row="1"
                x:Name="MainNavigationView"
                IsBackButtonVisible="Collapsed"
                PaneDisplayMode="Top"
                SelectionChanged="MainNavigationView_SelectionChanged"
                IsSettingsVisible="False"
                >

                <!-- Navigation items -->
                <NavigationView.MenuItems>
                    <NavigationViewItem Content="Dictionary" Tag="Dictionary" Icon="TwoPage" />
                    <NavigationViewItem Content="Translate" Tag="Translate" Icon="Globe" />
                    <NavigationViewItem Content="AI" Tag="AI" Icon="Contact" x:Name="AINavViewItem" />
                </NavigationView.MenuItems>

                <!-- Main content area -->
                <Grid>

                    <!-- Dictionary page -->
                    <StackPanel x:Name="DictionaryPage" Margin="10">
                        <TextBlock Text="Selected Word:" FontWeight="Bold" />
                        <TextBlock x:Name="SelectedWordText" Margin="0,5,0,10" />

                        <TextBlock Text="Reading:" FontWeight="Bold" />
                        <TextBlock x:Name="ReadingText" Margin="0,5,0,10" />

                        <TextBlock Text="Definition:" FontWeight="Bold" />
                        <TextBlock x:Name="DefinitionText" Margin="0,5,0,10" />
                    </StackPanel>

                    <!-- Translate page -->
                    <WebView2
            x:Name="TranslatePage"
            Margin="10"
            Visibility="Collapsed" />

                    <!-- AI page -->
                    <Grid x:Name="AIPage" Margin="10" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0">
                            <StackPanel x:Name="ChatStackPanel" />
                        </ScrollViewer>

                        <TextBox
                Grid.Row="1"
                x:Name="ExplainTextBox"
                Margin="0,10,0,0" />
                    </Grid>

                </Grid>
            </NavigationView>

        </Grid>
    </Border>
</UserControl>
