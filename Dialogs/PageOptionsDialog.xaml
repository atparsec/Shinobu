<UserControl
    x:Class="Shinobu.Dialogs.PageOptionsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Shinobu.Dialogs"
    xmlns:helpers="using:Shinobu.Helpers"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
     MaxWidth="600"
    MinWidth="600"
    MinHeight="500"
    MaxHeight="600">

    <UserControl.Resources>
        <helpers:StringToSolidColorBrushConverter x:Key="StringToBrushConverter"/>
        <helpers:BoolToSolidColorBrushConverter x:Key="BoolToBorderBrushConverter"/>
        <helpers:BoolToThicknessConverter x:Key="BoolToThicknessConverter"/>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Border Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}" CornerRadius="8" BorderBrush="{ThemeResource ControlElevationBorderBrush}" BorderThickness="1" Padding="12">
        <ScrollViewer VerticalScrollBarVisibility="Visible">
            <StackPanel Margin="24" Spacing="32" MaxWidth="550">
                <StackPanel Spacing="12">
                    <TextBlock Text="Theme" 
                           FontSize="18" 
                           FontWeight="SemiBold" 
                           Margin="0,8,0,8"/>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <GridView x:Name="ThemesGridView" ItemsSource="{x:Bind ThemeViewModels, Mode=OneWay}" Padding="0,10,0,0">
                            <GridView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="100" Height="60">
                                        <Border Background="{Binding DisplayBackground, Converter={StaticResource StringToBrushConverter}}"
                                            BorderThickness="{Binding IsSelected, Converter={StaticResource BoolToThicknessConverter}}"
                                            CornerRadius="6"
                                            PointerPressed="ThemeBorder_PointerPressed"
                                            BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToBorderBrushConverter}}"
                                            Tag="{Binding Theme.Name}">
                                        <TextBlock Text="{Binding Theme.Name}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="{Binding DisplayForeground, Converter={StaticResource StringToBrushConverter}}"/>
                                        </Border>
                                        <Button x:Name="DeleteThemeButton"
                                            Width="24" Height="24"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Margin="0,5,5,0"
                                            Padding="0"
                                            BorderThickness="0"
                                            CornerRadius="12"
                                            Visibility="{Binding CanDelete, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Click="DeleteThemeButton_Click"
                                            Tag="{Binding Theme.Name}">
                                            <Button.Background>
                                                <SolidColorBrush Color="{ThemeResource SystemColorButtonFaceColor}"/>
                                            </Button.Background>
                                            <FontIcon Glyph="&#xE74D;" FontFamily="Segoe Fluent Icons" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>
                    </ScrollViewer>
                    <Button x:Name="CustomThemeButton" Content="Custom..." Click="CustomThemeButton_Click" HorizontalAlignment="Left"/>
                </StackPanel>

                <StackPanel Spacing="12">
                    <TextBlock Text="Font Options" 
                           FontSize="18" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                        <TextBlock Text="Font Family" 
                               VerticalAlignment="Center" 
                               FontWeight="Medium"
                               MinWidth="100"/>
                        <ComboBox x:Name="FontFamilyComboBox" 
                              Width="240" 
                              PlaceholderText="Select font..." 
                              SelectionChanged="FontFamilyComboBox_SelectionChanged"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,8,0,0">
                        <TextBlock Text="Font Size" 
                               VerticalAlignment="Center" 
                               FontWeight="Medium"
                               MinWidth="100"/>
                        <ComboBox x:Name="FontSizeComboBox" 
                              Width="140" 
                              SelectionChanged="FontSizeComboBox_SelectionChanged"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,8,0,0">
                        <TextBlock Text="Style" 
                               VerticalAlignment="Center" 
                               FontWeight="Medium"
                               MinWidth="100"/>
                        <Button x:Name="BoldButton" FontWeight="Bold"   Width="48" Click="StyleButton_Click" Tag="Bold">
                            <FontIcon Glyph="" />
                        </Button>
                        <Button x:Name="ItalicButton" FontStyle="Italic" Width="48" Click="StyleButton_Click" Tag="Italic">
                            <FontIcon Glyph="" />
                        </Button>
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="12">
                    <TextBlock Text="Page" 
                           FontSize="18" 
                           FontWeight="SemiBold" 
                           Margin="0,8,0,8"/>

                    <TextBlock Text="Orientation" FontWeight="Medium" Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal" Spacing="24" HorizontalAlignment="Left">
                        <!-- Horizontal layout preview -->
                        <RadioButton x:Name="HorizontalRadio" 
                                 GroupName="PageOrientation"
                                 Checked="OrientationRadio_Checked"
                                 Style="{StaticResource RadioButtonWithPreview}">
                            <StackPanel Orientation="Vertical" Spacing="8" Margin="10,0,0,0">
                                <Border Background="#222" CornerRadius="6" Padding="12" Width="140" Height="90">
                                    <StackPanel Orientation="Vertical" Spacing="6">
                                        <Rectangle Fill="Gray" Width="130" Height="10"/>
                                        <Rectangle Fill="Gray" Width="130" Height="10"/>
                                        <Rectangle Fill="Gray" Width="130" Height="10"/>
                                        <Rectangle Fill="Gray" Width="130" Height="10"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="Horizontal" 
                                       HorizontalAlignment="Center" 
                                       FontSize="13"/>
                            </StackPanel>
                        </RadioButton>

                        <!-- Vertical layout preview -->
                        <RadioButton x:Name="VerticalRadio" 
                                 GroupName="PageOrientation"
                                 Checked="OrientationRadio_Checked"
                                 Style="{StaticResource RadioButtonWithPreview}">
                            <StackPanel Orientation="Vertical" Spacing="8" Margin="10,0,0,0">
                                <Border Background="#222" CornerRadius="6" Padding="12" Width="140" Height="90">
                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                        <Rectangle Fill="Gray" Width="10" Height="80"/>
                                        <Rectangle Fill="Gray" Width="10" Height="80"/>
                                        <Rectangle Fill="Gray" Width="10" Height="80"/>
                                        <Rectangle Fill="Gray" Width="10" Height="80"/>
                                        <Rectangle Fill="Gray" Width="10" Height="80"/>
                                        <Rectangle Fill="Gray" Width="10" Height="80"/>
                                        <Rectangle Fill="Gray" Width="10" Height="80"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="Vertical" 
                                       HorizontalAlignment="Center" 
                                       FontSize="13"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,16,0,0">
                        <TextBlock Text="Page Margin" 
                               VerticalAlignment="Center" 
                               FontWeight="Medium"
                               MinWidth="100"/>
                        <ComboBox x:Name="PageMarginComboBox" 
                              Width="160" 
                              SelectionChanged="PageMarginComboBox_SelectionChanged"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <TextBlock Text="Line Spacing" 
                               VerticalAlignment="Center" 
                               FontWeight="Medium"
                               MinWidth="100"/>
                        <ComboBox x:Name="LineSpacingComboBox" 
                              Width="160" 
                              SelectionChanged="LineSpacingComboBox_SelectionChanged"/>
                    </StackPanel>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>