<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Shinobu.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Shinobu"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Shinobu"
    >

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid AllowDrop="True" Drop="Grid_Drop" DragOver="Grid_DragOver" DragLeave="Grid_DragLeave">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
        x:Name="titleBar"
        IsBackButtonVisible="{x:Bind navFrame.CanGoBack, Mode=OneWay}"
            Title="Shinobu"
            Subtitle="Preview"
        >
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="/Assets/Square44x44Logo.png"/>
            </TitleBar.IconSource>

            <TitleBar.Content>
                <AutoSuggestBox
                    x:Name="searchBox"
                    Width="360"
                    VerticalAlignment="Center"
                    PlaceholderText="Search.."
                    QueryIcon="Find"
                    TextChanged="SearchBox_TextChanged"
                    QuerySubmitted="SearchBox_QuerySubmitted" />
            </TitleBar.Content>

        </TitleBar>

        <NavigationView
        x:Name="navView"
        Grid.Row="1"
        IsBackButtonVisible="Collapsed"
        IsPaneToggleButtonVisible="True"
        ItemInvoked="NavView_ItemInvoked"
        BackRequested="NavView_BackRequested"
        >
            <NavigationView.MenuItems>
                <NavigationViewItem
                    Content="Library"
                    Icon="Library"
                    Tag="library" />
                <NavigationViewItem
                    Content="Reader"
                    Icon="TwoPage"
                    Tag="reader" />
                <NavigationViewItem
                    Content="Bookmarks"
                    Icon="Tag"
                    Tag="bookmarks">
                    <NavigationViewItem.InfoBadge>
                        <InfoBadge
                            x:Name="bookmarkBadge"
                            Background="Gray"
                            Foreground="White"
                            Visibility="Collapsed"
                            />
                    </NavigationViewItem.InfoBadge>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="Image OCR"
                    Icon="Camera"
                    Tag="imageocr" />
            </NavigationView.MenuItems>
            <Frame x:Name="navFrame" />
        </NavigationView>


        <Border x:Name="LoadingRing" Grid.Row="0" Grid.RowSpan="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"  Background="#8D000000" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20" CornerRadius="10">
                <ProgressRing IsActive="True" HorizontalAlignment="Center" VerticalAlignment="Center" />
                <TextBlock Text="Adding Book to Library..." HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" Foreground="White" Margin="0,10,0,0"/>
                <TextBlock Text="Parsing for the first time can take a few seconds." HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Foreground="LightGray" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
        
        <Border Grid.Row="0" Grid.RowSpan="2" Visibility="{x:Bind IsDragOver, Mode=OneWay}" Background="#5D000000" BorderBrush="{StaticResource AccentAAFillColorDefaultBrush}" BorderThickness="3" CornerRadius="10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <TextBlock Text="Drop file here" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24" Foreground="White" />
        </Border>

    </Grid>
</Window>
