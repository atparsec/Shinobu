<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Shinobu.Pages.LibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Shinobu"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Library" FontSize="32" FontWeight="Bold" />

        <StackPanel x:Name="FavoritesSection" Grid.Row="1" Visibility="Collapsed" Margin="0,20,0,0">
            <TextBlock Text="Favorites" FontSize="24" FontWeight="SemiBold" />
            <GridView x:Name="FavoritesGrid" SelectionMode="Single" Padding="0">
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <!-- Card for each book/file -->
                        <StackPanel
                        Width="150"
                        Height="200"
                        Padding="10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                            Shadow="{ThemeResource CommandBarFlyoutOverflowShadow}"
                        Spacing="10"
                        PointerEntered="Card_PointerEntered"
                        PointerExited="Card_PointerExited">

                            <TextBlock
                            Text="{Binding FileName}"
                            TextWrapping="WrapWholeWords"
                            Style="{ThemeResource BodyStrongTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                            <TextBlock
                            Text="{Binding FileSize, Converter={StaticResource FileSizeConverter}}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                            <TextBlock
                            Text="{Binding DateModified}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                            <TextBlock
                            Text="{Binding PreviewText}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap"
                            MaxLines="3" />

                            <Button x:Name="FavoriteButton" Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Click="FavoriteButton_Click">
                                <TextBlock Text="{Binding IsFavorite, Converter={StaticResource BoolToStringConverter}}" FontSize="20" />
                            </Button>
                        </StackPanel>
                    </DataTemplate>
                </GridView.ItemTemplate>

                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VariableSizedWrapGrid Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
            </GridView>
        </StackPanel>

        <TextBlock Grid.Row="2" Text="All Books" FontSize="24" FontWeight="SemiBold" Margin="0,20,0,0" />

        <GridView
        x:Name="BooksGrid"
        Grid.Row="3"
        SelectionMode="Single"
        Padding="0">
            <GridView.ItemTemplate>
                <DataTemplate>
                    <!-- Card for each book/file -->
                    <StackPanel
                    Width="150"
                    Height="200"
                    Padding="10"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                        Shadow="{ThemeResource CommandBarFlyoutOverflowShadow}"
                    Spacing="10"
                    PointerEntered="Card_PointerEntered"
                    PointerExited="Card_PointerExited">

                        <TextBlock
                        Text="{Binding FileName}"
                        TextWrapping="WrapWholeWords"
                        Style="{ThemeResource BodyStrongTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                        <TextBlock
                        Text="{Binding FileSize, Converter={StaticResource FileSizeConverter}}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <TextBlock
                        Text="{Binding DateModified}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <Button x:Name="FavoriteButton" Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Click="FavoriteButton_Click">
                            <TextBlock Text="{Binding IsFavorite, Converter={StaticResource BoolToStringConverter}}" FontSize="20" />
                        </Button>
                    </StackPanel>
                </DataTemplate>
            </GridView.ItemTemplate>

            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <VariableSizedWrapGrid Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
        </GridView>
    </Grid>

</Page>
