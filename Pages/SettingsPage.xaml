<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Shinobu.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Shinobu"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer x:Name="RootScrollViewer">
        <StackPanel Padding="24" Spacing="30">
            <TextBlock Text="Settings" FontSize="32" FontWeight="Bold" />

            <!-- General -->
            <Expander x:Name="GeneralSection" Header="General" IsExpanded="True" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                <StackPanel Margin="8,8,0,0" Spacing="12">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                        <TextBlock Text="Library Folder" VerticalAlignment="Center" Width="160" />
                        <TextBox x:Name="LibraryFolderTextBox" Width="420" PlaceholderText="Select library folder..." TextChanged="LibraryFolderTextBox_TextChanged"/>
                        <Button x:Name="BrowseButton" Content="Browse" Click="BrowseButton_Click"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                        <TextBlock Text="Select Dictionary" VerticalAlignment="Center" Width="160" />
                        <ComboBox x:Name="DictionaryComboBox" Width="200" SelectionChanged="DictionaryComboBox_SelectionChanged">
                            <ComboBoxItem Content="Local" />
                            <ComboBoxItem Content="Jisho" />
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Expander>

            <!-- Appearance -->
            <Expander x:Name="AppearanceSection" Header="Appearance" IsExpanded="True" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                <StackPanel Margin="8,8,0,0" Spacing="12">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                        <TextBlock Text="Theme" VerticalAlignment="Center" Width="160" />
                        <ComboBox x:Name="ThemeComboBox" Width="200" SelectionChanged="ThemeComboBox_SelectionChanged">
                            <ComboBoxItem Content="Light" />
                            <ComboBoxItem Content="Dark" />
                            <ComboBoxItem Content="System Default" />
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Expander>

            <!-- AI Features -->
            <Expander x:Name="AIFeaturesSection" Header="AI Features" IsExpanded="True" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                <StackPanel Margin="8,8,0,0" Spacing="12">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                        <TextBlock Text="Enable AI Features?" VerticalAlignment="Center" Width="160" />
                        <ToggleSwitch x:Name="EnableAIFeaturesToggle" Toggled="EnableAIFeaturesToggle_Toggled"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                        <TextBlock Text="Select AI Provider" VerticalAlignment="Center" Width="160" />
                        <ComboBox x:Name="AIProviderComboBox" Width="200" SelectionChanged="AIProviderComboBox_SelectionChanged">
                            <ComboBoxItem Content="Grok" />
                            <ComboBoxItem Content="OpenAI" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                        <TextBlock Text="Enter API Key" VerticalAlignment="Center" Width="160" />
                        <PasswordBox x:Name="ApiKeyBox" Width="420" PlaceholderText="Paste API key here" PasswordChanged="ApiKeyBox_PasswordChanged" />
                    </StackPanel>
                </StackPanel>
            </Expander>

            <!-- About -->
            <Expander x:Name="AboutSection" Header="About" IsExpanded="True" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                <StackPanel Margin="8,8,0,0" Spacing="12">
                    <TextBlock TextWrapping="Wrap">
                        TODO
                    </TextBlock>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Version" VerticalAlignment="Center" Width="160" />
                        <TextBlock Text="1.0.0 (preview)" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Expander>

            <!-- Updates -->
            <Expander x:Name="UpdatesSection" Header="Updates" IsExpanded="True" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                <StackPanel Margin="8,8,0,0" Spacing="12">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                        <TextBlock Text="Check for updates" VerticalAlignment="Center" Width="160" />
                        <Button Content="Check Now" />
                    </StackPanel>

                    <TextBlock TextWrapping="Wrap" Foreground="Gray">TODO</TextBlock>
                </StackPanel>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</Page>
